{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "nextjs-frontend"
    },
    {
      "name": "FastAPI Backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload"],
      "port": 8000,
      "cwd": "backend"
    },
    {
      "name": "Docker Services (PostgreSQL, Redis, Qdrant)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "-d"],
      "port": 5432,
      "cwd": "backend"
    }
  ]
}
